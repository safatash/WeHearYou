generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  ANALYST
  SUPPORT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  WEBHOOK
  API
}

enum ContactStatus {
  ACTIVE
  NEEDS_FOLLOW_UP
  ARCHIVED
}

enum PreferredChannel {
  SMS
  EMAIL
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  OPENED
  CLICKED
  COMPLETED
  FAILED
}

enum ReviewSource {
  GOOGLE
  FACEBOOK
  YELP
  INTERNAL
}

enum ReviewStatus {
  PUBLISHED
  NEEDS_FOLLOW_UP
  PRIVATE_FEEDBACK
}

enum AutomationTriggerType {
  APPOINTMENT_COMPLETED
  PROJECT_COMPLETED
  MANUAL_ENROLLMENT
  WEBHOOK_EVENT
}

enum AutomationStepType {
  DELAY
  SEND_REQUEST
  TAG_CONTACT
  NOTIFY_TEAM
  WEBHOOK
  PUBLISH_GBP_REPLY
}

enum VideoTestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ThumbnailSource {
  DEFAULT
  CUSTOM
  CAPTURED
}

enum GbpPostType {
  WHATS_NEW
  OFFER
  EVENT
}

enum GbpPublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  EXPIRED
}

enum ReviewLinkEventType {
  LINK_VIEWED
  HAPPY_CLICKED
  UNHAPPY_CLICKED
  GOOGLE_REDIRECT_CLICKED
  FEEDBACK_STARTED
  FEEDBACK_SUBMITTED
  MINISITE_VIEWED
  MINISITE_CLICK_REVIEW
  MINISITE_CLICK_CALL
  MINISITE_CLICK_WEBSITE
  MINISITE_CLICK_DIRECTIONS
  MINISITE_CLICK_CTA
  AI_ASSIST_VIEWED
  AI_ASSIST_GENERATED
  AI_ASSIST_REGENERATED
  AI_ASSIST_EDITED
  AI_ASSIST_COPIED
  AI_ASSIST_DEST_GOOGLE
  AI_ASSIST_DEST_YELP
  AI_ASSIST_DEST_FACEBOOK
  AI_ASSIST_DEST_TRUSTPILOT
  AI_ASSIST_WEHEARYOU_SUBMITTED
  RESOLUTION_VIEWED
  RESOLUTION_ISSUE_SELECTED
  RESOLUTION_FEEDBACK_STARTED
  RESOLUTION_AI_REWRITE_GENERATED
  RESOLUTION_AI_REWRITE_ACCEPTED
  START_FROM_SCRATCH_SELECTED
  MANUAL_WRITING_STARTED
  MANUAL_REVIEW_COMPLETED
  AI_DRAFT_ACCEPTED
  AI_ASSIST_TOOL_USED
  RESOLUTION_FEEDBACK_SUBMITTED
  RESOLUTION_CONTACT_REQUESTED
  RESOLUTION_CASE_CREATED
  RESOLUTION_RESPONSE_DRAFTED
  RESOLUTION_CASE_RESOLVED
  RESOLUTION_FOLLOWUP_SENT
  RESOLUTION_FOLLOWUP_COMPLETED
}

enum ResolutionStatus {
  NEW
  NEEDS_RESPONSE
  CONTACTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ResolutionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ResolutionContactPreference {
  PHONE
  EMAIL
  NONE
}

model Organization {
  id                String                  @id @default(cuid())
  name              String
  slug              String                  @unique
  website           String?
  aiReplyEnabled    Boolean                 @default(false)
  suspendedAt       DateTime?
  onboardingDismissedAt DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  users             UserMembership[]
  locations         Location[]
  automations       Automation[]
  googleConnections GoogleAccountConnection[]
  metaConnections   MetaAccountConnection[]
  reviewWidgets     ReviewWidget[]
  reviewLinkEvents  ReviewLinkEvent[]
  reviewAssistantSessions ReviewAssistantSession[]
  resolutionCases   ResolutionCase[]
}

model User {
  id          String           @id @default(cuid())
  name        String
  email       String           @unique
  passwordHash String?
  emailVerified DateTime?
  avatarUrl   String?
  isSuperAdmin Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  memberships UserMembership[]
  accounts    Account[]
  sessions    Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserMembership {
  id             String            @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole
  status         MembershipStatus  @default(INVITED)
  accessScope    String?
  inviteToken    String?           @unique
  inviteSentAt   DateTime?
  invitedByUserId String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedReviews    Review[]
  sentReplies     Review[]                 @relation("ReviewReplySender")
  locationAccess  MembershipLocationAccess[]
  assignedResolutionCases ResolutionCase[]
  resolutionCaseNotes     ResolutionCaseNote[]

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model MembershipLocationAccess {
  membershipId    String
  locationId      String
  createdAt       DateTime      @default(now())

  membership      UserMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([membershipId, locationId])
  @@index([locationId])
}

model Location {
  id                    String        @id @default(cuid())
  organizationId        String
  googleConnectionId    String?
  metaConnectionId      String?
  name                  String
  slug                  String        @unique
  city                  String
  state                 String
  status                String
  reviewLink            String?
  managerName           String?
  avgRating             Float?
  googleLocationId      String?
  googlePlaceId         String?
  googleLocationName    String?
  googleConnectedAt     DateTime?
  yelpBusinessUrl       String?
  yelpBusinessName      String?
  yelpBusinessId        String?
  yelpConnectedAt       DateTime?
  yelpLastSyncAt        DateTime?
  yelpLastSyncStatus    String?
  yelpLastSyncCount     Int?
  googleAutoReplyEnabled Boolean      @default(false)
  googleAutoReplyThreshold Int        @default(4)
  googleAutoReplyDailyCap Int         @default(0)
  googleAutoReplyLastUsedAt DateTime?
  lastSyncStatus        String?
  lastSyncMessage       String?
  lastSyncImportedCount Int?
  lastSyncUpdatedCount  Int?
  lastSyncSkippedCount  Int?
  lastSyncFetchedCount  Int?
  lastSyncAt            DateTime?
  miniSitePublished     Boolean       @default(false)
  miniSitePublishedAt   DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  organization          Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  googleConnection      GoogleAccountConnection? @relation(fields: [googleConnectionId], references: [id], onDelete: SetNull)
  metaConnection        MetaAccountConnection? @relation(fields: [metaConnectionId], references: [id], onDelete: SetNull)
  publicProfile         LocationPublicProfile?
  contacts              Contact[]
  campaigns             Campaign[]
  reviews               Review[]
  automationRuns        AutomationRun[]
  membershipAccess      MembershipLocationAccess[]
  reviewWidgets         ReviewWidget[]
  videoTestimonials     VideoTestimonial[]
  gbpPosts              GbpPost[]
  gbpPhotos             GbpPhoto[]
  gbpQuestions          GbpQuestion[]
  gbpSyncLogs           GbpSyncLog[]
  reviewLinkEvents      ReviewLinkEvent[]
  reviewAssistantSessions ReviewAssistantSession[]
  resolutionCases       ResolutionCase[]
  resolutionSettings    ResolutionAssistantSettings?

  @@index([organizationId])
  @@index([googleConnectionId])
  @@index([metaConnectionId])
  @@index([googleLocationId])
}

model Contact {
  id               String           @id @default(cuid())
  locationId       String
  firstName        String?
  lastName         String?
  name             String
  email            String?
  phone            String?
  source           ContactSource
  status           ContactStatus    @default(ACTIVE)
  preferredChannel PreferredChannel @default(SMS)
  notes            String?
  lastInvitedAt    DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  location         Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tags             ContactTag[]
  campaigns        CampaignRecipient[]
  reviews          Review[]
  resolutionCases  ResolutionCase[]
  automationRuns   AutomationRun[]

  @@index([locationId])
  @@index([email])
  @@index([phone])
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contacts    ContactTag[]
}

model ContactTag {
  contactId   String
  tagId       String
  createdAt   DateTime @default(now())

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model Campaign {
  id              String             @id @default(cuid())
  locationId      String
  automationRunId String?
  name            String
  channel         PreferredChannel
  status          CampaignStatus     @default(DRAFT)
  workflowName    String?
  sendAt          DateTime?
  messageBody     String?
  emailSubject    String?
  destination     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  location        Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  automationRun   AutomationRun?        @relation(fields: [automationRunId], references: [id], onDelete: SetNull)
  recipients      CampaignRecipient[]
  stepExecution   AutomationStepExecution?

  @@index([locationId])
  @@index([status])
  @@index([automationRunId])
}

model CampaignRecipient {
  id             String         @id @default(cuid())
  campaignId     String
  contactId      String
  token          String         @unique
  status         CampaignStatus @default(DRAFT)
  outcome        String?
  sentAt         DateTime?
  openedAt       DateTime?
  completedAt    DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact        Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
  @@index([token])
}

model Review {
  id                    String        @id @default(cuid())
  locationId            String
  contactId             String?
  ownerMembershipId     String?
  source                ReviewSource
  externalId            String?
  reviewerName          String
  reviewerPhotoUrl      String?
  sourceReviewUrl       String?
  sourceReplyText       String?
  rating                Int?
  status                ReviewStatus
  sentiment             String?
  title                 String?
  body                  String
  reviewImageUrl        String?
  internalNotes         String?
  replyDraft            String?
  replyPublishedAt      DateTime?
  replyGbpId            String?
  replySentAt           DateTime?
  replySentByMembershipId String?
  isTestimonial         Boolean       @default(false)
  isFeatured            Boolean       @default(false)
  isWidgetVisible       Boolean       @default(false)
  isHiddenFromMiniSite  Boolean       @default(false)
  publishedExternally   Boolean       @default(false)
  legacySourceId        String?
  reviewedAt            DateTime?
  lastImportedAt        DateTime?
  sourceUpdatedAt       DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  location              Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  contact               Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerMembership       UserMembership? @relation(fields: [ownerMembershipId], references: [id], onDelete: SetNull)
  replySentByMembership UserMembership? @relation("ReviewReplySender", fields: [replySentByMembershipId], references: [id], onDelete: SetNull)
  resolutionCase        ResolutionCase?

  @@index([locationId])
  @@index([contactId])
  @@index([ownerMembershipId])
  @@index([replySentByMembershipId])
  @@index([source])
  @@index([isTestimonial])
  @@index([isWidgetVisible])
}

model ReplyAuditLog {
  id                     String        @id @default(cuid())
  reviewId               String
  locationId             String
  userId                 String?
  action                 String        // DRAFT_GENERATED, DRAFT_EDITED, SENT_TO_GOOGLE, FAILED, SAFETY_BLOCKED
  resultStatus           String        // SUCCESS, FAILED, BLOCKED
  draftText              String?
  errorMessage           String?
  safetyClassification   Json?         // { isRisky, riskCategories, reason }
  metadata               Json?         // { accountId, googleReviewId, httpStatus, etc }
  createdAt              DateTime      @default(now())

  @@index([reviewId])
  @@index([locationId])
  @@index([userId])
  @@index([action])
  @@index([resultStatus])
}

model Automation {
  id             String                 @id @default(cuid())
  organizationId String
  name           String
  triggerType    AutomationTriggerType
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps          AutomationStep[]
  runs           AutomationRun[]

  @@index([organizationId])
}

model AutomationStep {
  id             String              @id @default(cuid())
  automationId   String
  stepType       AutomationStepType
  title          String
  description    String?
  orderIndex     Int
  configJson     Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  automation     Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  queuedJobs     AutomationJob[]
  stepExecutions AutomationStepExecution[]

  @@index([automationId])
  @@unique([automationId, orderIndex])
}

model AutomationRun {
  id             String        @id @default(cuid())
  automationId   String
  locationId     String
  contactId      String
  triggerEvent   String
  source         String?
  status         String        @default("pending")
  payloadJson    Json?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  automation     Automation    @relation(fields: [automationId], references: [id], onDelete: Cascade)
  location       Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  jobs           AutomationJob[]
  stepExecutions AutomationStepExecution[]
  campaigns      Campaign[]

  @@index([automationId])
  @@index([locationId])
  @@index([contactId])
  @@index([status])
}

model AutomationJob {
  id                String          @id @default(cuid())
  automationRunId   String
  automationStepId  String
  status            String          @default("pending")
  executeAt         DateTime
  executedAt        DateTime?
  errorMessage      String?
  attemptCount      Int             @default(0)
  maxAttempts       Int             @default(3)
  payloadJson       Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  automationRun     AutomationRun   @relation(fields: [automationRunId], references: [id], onDelete: Cascade)
  automationStep    AutomationStep  @relation(fields: [automationStepId], references: [id], onDelete: Cascade)
  stepExecution     AutomationStepExecution?

  @@index([automationRunId])
  @@index([automationStepId])
  @@index([status, executeAt])
}

model AutomationStepExecution {
  id               String          @id @default(cuid())
  automationRunId  String
  automationStepId String
  automationJobId  String?         @unique
  campaignId       String?         @unique
  status           String
  detail           String?
  errorMessage     String?
  startedAt        DateTime        @default(now())
  completedAt      DateTime?
  createdAt        DateTime        @default(now())

  automationRun    AutomationRun   @relation(fields: [automationRunId], references: [id], onDelete: Cascade)
  automationStep   AutomationStep  @relation(fields: [automationStepId], references: [id], onDelete: Cascade)
  automationJob    AutomationJob?  @relation(fields: [automationJobId], references: [id], onDelete: SetNull)
  campaign         Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([automationRunId])
  @@index([automationStepId])
}

model GoogleAccountConnection {
  id                   String        @id @default(cuid())
  organizationId       String
  providerAccountId    String?
  email                String?
  accessToken          String?
  refreshToken         String?
  tokenType            String?
  scope                String?
  expiresAt            DateTime?
  lastSyncedAt         DateTime?
  lastBatchSyncStatus  String?
  lastBatchSyncMessage String?
  lastBatchSyncedCount Int?
  lastBatchFailedCount Int?
  lastBatchFailedNames String?
  lastBatchImportedCount Int?
  lastBatchUpdatedCount Int?
  lastBatchSkippedCount Int?
  lastBatchFetchedCount Int?
  lastBatchSyncAt      DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations            Location[]

  @@index([organizationId])
  @@index([providerAccountId])
}

model MetaAccountConnection {
  id                   String        @id @default(cuid())
  organizationId       String
  pageId               String?
  pageName             String?
  accessToken          String?
  tokenType            String?
  expiresAt            DateTime?
  lastSyncedAt         DateTime?
  lastBatchSyncStatus  String?
  lastBatchSyncMessage String?
  lastBatchSyncedCount Int?
  lastBatchFailedCount Int?
  lastBatchFailedNames String?
  lastBatchImportedCount Int?
  lastBatchUpdatedCount Int?
  lastBatchSkippedCount Int?
  lastBatchFetchedCount Int?
  lastBatchSyncAt      DateTime?
  reviewCount          Int           @default(0)
  connectedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  organization         Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  locations            Location[]

  @@index([organizationId])
}

model ReviewWidget {
  id               String       @id @default(cuid())
  organizationId   String
  locationId       String
  name             String
  publicToken      String       @unique
  isActive         Boolean      @default(true)
  contentType      String       @default("TEXT")

  layout           String       @default("grid")
  theme            String       @default("light")
  sort             String       @default("newest")
  minRating        Int          @default(1)
  pageSize         Int          @default(12)

  // Header panel
  showHeader       Boolean      @default(true)
  showAvgRating    Boolean      @default(true)
  showReviewCount  Boolean      @default(true)
  headerAlign      String       @default("left")

  // Review card panel
  showRating       Boolean      @default(true)
  showReviewerName Boolean      @default(true)
  showDate         Boolean      @default(true)
  showWriteReview  Boolean      @default(true)
  showResponses    Boolean      @default(false)
  showAiSummary    Boolean      @default(true)
  marqueeSpeed     String       @default("normal")
  bodyMaxChars     Int          @default(280)
  showNav          Boolean      @default(true)
  showPagination   Boolean      @default(true)

  // Appearance panel
  primaryColor     String       @default("#4338ca")
  starColor        String       @default("#f59e0b")
  starColorMode    String       @default("gold")    // "gold" | "accent" | "ink"
  backgroundColor  String       @default("#ffffff")
  textColor        String       @default("#0f172a")
  fontFamily       String       @default("system")  // system | sans | serif | round | mono
  fontSizeBase     Int          @default(14)        // body/review text (11-18px)
  fontSizeNames    Int          @default(13)        // reviewer names (10-16px)
  fontSizeHeader   Int          @default(20)        // widget header title (14-28px)
  fontSizeLabel    Int          @default(12)        // dates, labels, secondary text (10-14px)
  fontSizeSummary  Int          @default(14)        // AI summary body (11-16px)
  cornerRadius     Int          @default(12)         // 0..22 px
  cardStyle        String       @default("border")  // "border" | "shadow" | "soft"
  density          String       @default("cozy")    // "cozy" | "compact"
  gridColumns      String       @default("auto")    // "auto" | "2" | "3"
  wallStyle        String       @default("varied")  // "varied" | "uniform"
  enabledSources   String       @default("")         // CSV of GOOGLE,FACEBOOK,YELP,TRUSTPILOT; "" = all
  showBranding     Boolean      @default(true)
  collectTitle     String?
  collectSubtitle  String?

  // Widget type & single testimonial
  widgetType                 String?
  singleTestimonialReviewId  String?
  singleTestimonialVideoId   String?
  showSourceLogo             Boolean  @default(true)
  badgeStyle                 String?

  // Collecting Widget
  collectDisplayFreq         String?   // "always" | "50pct" | "33pct"
  collectButtonColor         String?   // hex override; null = inherit primaryColor
  collectButtonTheme         String?   // "default" | "minimal" | "branded"
  collectMobileBehavior      String?   // "pill" | "hidden"
  collectButtonPosition      String?   // "left" | "right" | "bottom-left" | "bottom-right"

  // Floating Widget
  floatingCardStyle           String?   // "dark_solid_pill" | "frosted_glass_pill" | "below_card" | "notification_compact"
  floatingVariation           String?   // "compact" | "standard" | "rich"
  floatingPosition            String?   // "bottom-right" | "bottom-left" | "left" | "right"
  floatingRotationEnabled     Boolean?
  floatingRotationIntervalSec Int?      // 5 | 8 | 12 | 30
  floatingAccentColorMode     String?   // "inherit" | "custom"
  floatingAccentColor         String?   // hex
  floatingMobileBehavior      String?   // "show" | "compact" | "hide"
  floatingApprovedOnly        Boolean?
  floatingMinRating           Int?      // 4 or 5
  floatingDisplayFrequency    String?   // "always" | "half" | "third"

  customCss        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location         Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([locationId])
  @@index([publicToken])
}

model LocationPublicProfile {
  id                   String      @id @default(cuid())
  locationId           String      @unique
  headline             String?
  subheadline          String?
  instagramUrl         String?
  facebookUrl          String?
  xUrl                 String?
  tiktokUrl            String?
  youtubeUrl           String?
  linkedinUrl          String?
  phone                String?
  email                String?
  addressLine1         String?
  addressLine2         String?
  postalCode           String?
  bookingUrl           String?
  ctaLabel             String?
  ctaUrl               String?
  logoUrl              String?
  heroImageUrl         String?
  googleMapsUrl        String?
  googleHours          String?
  theme                String?
  funnelRatingStyle    String?
  funnelStyle          String      @default("SIMPLE")   // SIMPLE | AI_GUIDED
  funnelPromptTitle    String?
  funnelPromptBody     String?
  funnelPrivateTitle   String?
  funnelPrivateBody    String?
  funnelPrivateSubmitLabel String?
  funnelThanksPublicTitle String?
  funnelThanksPublicBody  String?
  funnelThanksPrivateTitle String?
  funnelThanksPrivateBody  String?
  funnelReviewButtonLabel  String?
  negativeFilterEnabled    Boolean     @default(false)
  negativeFilterThreshold  Int         @default(4)
  // ── Review routing ──────────────────────────────────────────────────────
  // Low ratings (< negativeFilterThreshold): recovery only.
  lowRatingDestination     String      @default("PRIVATE")   // PRIVATE | CUSTOM
  lowRatingCustomUrl       String?                            // recovery URL when lowRatingDestination = CUSTOM
  // High ratings (>= negativeFilterThreshold): one or more public destinations.
  highRatingMode           String      @default("SINGLE")     // SINGLE | MULTIPLE (choice page)
  highRatingDestinations   String[]    @default(["GOOGLE"])   // subset of GOOGLE | FACEBOOK | WEHEARYOU | CUSTOM
  highRatingPrimaryDestination String?                        // highlighted option on the choice page (MULTIPLE)
  facebookReviewUrl        String?                            // FACEBOOK destination ("leave a review" URL)
  customReviewUrl          String?                            // CUSTOM high-rating review URL
  businessType         String?
  customDomain         String?
  showReviews          Boolean     @default(true)
  miniSiteReviewsPerPage Int       @default(12)
  showTestimonials     Boolean     @default(true)
  showMap              Boolean     @default(true)
  showHours            Boolean     @default(false)
  schemaEnabled        Boolean     @default(true)
  showAiReviewSummary        Boolean   @default(false)
  aiReviewSummary            String?
  aiReviewSummaryAt          DateTime?
  aiReviewSummaryReviewCount Int?
  // ── AI Review Assistant ─────────────────────────────────────────────────
  aiAssistantEnabled         Boolean   @default(false)
  aiAssistantAllowGeneration Boolean   @default(true)
  aiAssistantAllowTone       Boolean   @default(true)
  aiAssistantAllowLength     Boolean   @default(true)
  aiAssistantAllowRegenerate Boolean   @default(true)
  aiAssistantAllowNotes      Boolean   @default(true)
  aiAssistantIncludeBusiness Boolean   @default(true)
  aiAssistantIncludeCity     Boolean   @default(true)
  aiAssistantIncludeService  Boolean   @default(true)
  aiAssistantUseReviewThemes Boolean   @default(true)
  aiAssistantCustomChips     String[]  @default([])
  trustpilotReviewUrl        String?
  wehearyouReviewsEnabled    Boolean   @default(true)
  accentColor          String?
  websiteUrl           String?
  timezone             String?
  services             String[]    @default([])
  ctaType              String?     @default("REVIEW")
  secondaryCtaType     String?
  secondaryCtaLabel    String?
  enabledReviewSources String[]    @default([])
  reviewHighlights     String[]    @default([])
  showReviewSummary    Boolean     @default(true)
  showFeaturedReviews  Boolean     @default(true)
  showServices         Boolean     @default(true)
  showSourceBadges     Boolean     @default(true)
  showVerifiedBadge    Boolean     @default(true)
  showPoweredBy        Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  location             Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([customDomain])
}

model VideoTestimonial {
  id                    String                 @id @default(cuid())
  locationId            String
  token                 String                 @unique
  prompt                String?
  submitterName         String?
  submitterEmail        String?
  videoUrl              String?
  mimeType              String?
  durationSeconds       Int?
  caption               String?                // Admin-provided text accompanying the video
  customThumbnailUrl    String?                // Admin-uploaded custom thumbnail image
  capturedFrameUrl      String?                // Extracted frame from video
  capturedFrameTimestamp Float?                // Seconds into video where frame was captured
  thumbnailSource       ThumbnailSource        @default(DEFAULT) // Which thumbnail to display
  status                VideoTestimonialStatus @default(PENDING)
  publishedAt           DateTime?
  expiresAt             DateTime?
  usedAt                DateTime?
  revokedAt             DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  location              Location               @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([token])
  @@index([status])
}

model GbpPost {
  id            String           @id @default(cuid())
  locationId    String
  postType      GbpPostType
  content       String
  callToAction  Json?
  imageUrl      String?
  status        GbpPublishStatus @default(DRAFT)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  gbpPostId     String?
  failureReason String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  location      Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([status, scheduledAt])
}

model GbpPhoto {
  id            String           @id @default(cuid())
  locationId    String
  storageUrl    String
  category      String
  caption       String?
  status        GbpPublishStatus @default(DRAFT)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  gbpMediaId    String?
  failureReason String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  location      Location         @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([status, scheduledAt])
}

model GbpQuestion {
  id              String    @id @default(cuid())
  locationId      String
  gbpQuestionId   String    @unique
  questionText    String
  askedAt         DateTime
  answerText      String?
  answeredAt      DateTime?
  gbpAnswerId     String?
  syncedAt        DateTime

  location        Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([answeredAt])
}

model GbpSyncLog {
  id           String   @id @default(cuid())
  locationId   String
  syncType     String
  status       String
  itemsSynced  Int      @default(0)
  error        String?
  syncedAt     DateTime @default(now())

  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

model ReviewLinkEvent {
  id             String              @id @default(cuid())
  organizationId String
  locationId     String
  eventType      ReviewLinkEventType
  source         String?
  medium         String?
  placement      String?
  referrer       String?
  sessionId      String?
  clientIp       String?
  reviewLinkId   String?
  createdAt      DateTime            @default(now())

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  location       Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([organizationId, createdAt])
  @@index([locationId, createdAt])
  @@index([locationId, eventType, createdAt])
  @@index([locationId, source, createdAt])
  @@index([locationId, sessionId, createdAt])
  @@index([locationId, clientIp, createdAt])
}

model ReviewAssistantSession {
  id                  String   @id @default(cuid())
  organizationId      String
  locationId          String
  campaignRecipientId String?
  rating              Int
  selectedPhrases     String[] @default([])
  service             String?
  staffMember         String?
  notes               String?
  generatedReview     String?
  tone                String?
  length              String?
  destination         String?
  reviewCopied        Boolean  @default(false)
  destinationClicked  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location            Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, createdAt])
  @@index([organizationId, createdAt])
}

model ResolutionAssistantSettings {
  id                          String   @id @default(cuid())
  locationId                  String   @unique
  enabled                     Boolean  @default(false)
  allowAiRewrite              Boolean  @default(true)
  allowAiSummary              Boolean  @default(true)
  allowPriorityClassification Boolean  @default(true)
  allowAiResponseDrafts       Boolean  @default(true)
  followUpEnabled             Boolean  @default(true)
  notifyOnNewFeedback         Boolean  @default(true)
  notifyOnlyHighCritical      Boolean  @default(false)
  notifyEmails                String[] @default([])
  notifySmsRecipients         String[] @default([])
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  location                    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model ResolutionCase {
  id                  String                      @id @default(cuid())
  organizationId      String
  locationId          String
  campaignRecipientId String?
  reviewId            String?                     @unique
  contactId           String?
  rating              Int
  issueCategories     String[]                    @default([])
  originalFeedback    String
  aiClearFeedback     String?
  finalFeedback       String
  contactPreference   ResolutionContactPreference @default(NONE)
  customerName        String?
  customerEmail       String?
  customerPhone       String?
  requestedOutcome    String?
  aiSummary           String?
  priority            ResolutionPriority          @default(MEDIUM)
  status              ResolutionStatus            @default(NEW)
  assignedToMembershipId String?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  resolvedAt          DateTime?
  closedAt            DateTime?

  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location            Location                    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  review              Review?                     @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  contact             Contact?                    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo          UserMembership?             @relation(fields: [assignedToMembershipId], references: [id], onDelete: SetNull)
  notes               ResolutionCaseNote[]
  followUps           ResolutionFollowUp[]

  @@index([locationId, status, createdAt])
  @@index([organizationId, createdAt])
  @@index([priority])
}

model ResolutionCaseNote {
  id           String          @id @default(cuid())
  caseId       String
  membershipId String?
  kind         String          @default("NOTE")
  body         String
  metadata     Json?
  createdAt    DateTime        @default(now())

  case         ResolutionCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  membership   UserMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([caseId, createdAt])
}

model ResolutionFollowUp {
  id            String         @id @default(cuid())
  caseId        String
  token         String         @unique
  channel       String?
  sentAt        DateTime?
  response      String?
  responseDetail String?
  respondedAt   DateTime?
  createdAt     DateTime       @default(now())

  case          ResolutionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}
