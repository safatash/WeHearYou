DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?schema=public"

# Optional Google Business Profile OAuth config
# If these are blank, the app still runs, but Google connect/sync cannot complete.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_PLACES_API_KEY=""

# Required in production: signs Google OAuth state to prevent CSRF/tampering.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=""

# Required in production: AES-256-GCM key for encrypting stored Google tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Existing plaintext tokens continue to work until next refresh/reconnect (graceful migration).
TOKEN_ENCRYPTION_KEY=""

# Shared secret required on POST /api/webhooks/automation via the x-automation-secret header
AUTOMATION_WEBHOOK_SECRET=""

# Shared secret for POST /api/automation/run-pending via x-automation-runner-secret.
# If blank, the runner falls back to AUTOMATION_WEBHOOK_SECRET.
AUTOMATION_RUNNER_SECRET=""

# Used for graceful redirects in some setup-error cases
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI — required for AI reply generation (Pro feature)
OPENAI_API_KEY=""

# Email delivery (Resend) — powers team invite emails, review request emails,
# video testimonial request emails, and automation NOTIFY_TEAM steps.
# If RESEND_API_KEY is blank, email is skipped (invites still create a shareable
# link); SMS/other paths are unaffected.
RESEND_API_KEY=""
# Verified sender address for all outgoing email. Falls back to Resend's
# onboarding@resend.dev sandbox sender when blank.
RESEND_FROM_EMAIL=""

# SMS delivery (Twilio) — powers review request SMS and automation SEND_REQUEST
# steps on the SMS channel. All three are required for SMS to send; if any is
# blank, SMS delivery is skipped.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Vercel Blob storage — required for video testimonial uploads, custom thumbnail
# uploads, and captured-frame storage. Without it, video recording/upload fails.
# NOTE: the code reads this exact (non-standard) casing, so the variable name
# must match it verbatim — not Vercel's default BLOB_READ_WRITE_TOKEN.
BLOB_Public_READ_WRITE_TOKEN=""

# Cron authentication — Bearer secret required on GET /api/cron (automation job
# runner) and GET /api/cron/gbp (GBP post/photo scheduler + review sync).
# Requests without "Authorization: Bearer <CRON_SECRET>" are rejected, so the
# scheduled jobs will not run until this is set.
CRON_SECRET=""

# ── Facebook Reviews integration (SPIKE / proof-of-access only) ──────────────
# Meta Graph API app credentials. Not yet wired into product features; used for
# verifying access to Page recommendations (GET /{page-id}/ratings).
META_APP_ID=""
META_APP_SECRET=""
# Graph API version the client targets. Defaults to v23.0 when unset/invalid.
META_GRAPH_API_VERSION="v23.0"
# LOCAL VERIFICATION ONLY — do NOT commit real values. A short-lived Page access
# token and the Page id for the spike route (GET /api/dev/meta-ratings-spike).
# Page tokens are secrets: keep them in your gitignored .env, never here.
META_TEST_PAGE_ID=""
META_TEST_PAGE_TOKEN=""
