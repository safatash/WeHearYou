# Required: PostgreSQL database connection string.
# For Supabase, use the direct PostgreSQL URI for Prisma migrations when possible.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public"

# Required in production for Auth.js/NextAuth session encryption.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_SECRET=""

# Public app URL used by OAuth callbacks and links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: required only for Google Business Profile OAuth/sync.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
GOOGLE_PLACES_API_KEY=""

# Optional: email delivery.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
